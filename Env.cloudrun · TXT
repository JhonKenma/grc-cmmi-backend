# ================================================================
# VARIABLES DE ENTORNO PARA CLOUD RUN
# Configura estas en: GCP Console → Cloud Run → Edit → Variables
# ================================================================

# ── DJANGO ──────────────────────────────────────────────────────
ENVIRONMENT=production
SECRET_KEY=cambiar-por-una-clave-segura-larga
DEBUG=False

# Reemplaza con tu URL real de Cloud Run después del primer deploy
# Ejemplo: shieldgrid-backend-abc123-uc.a.run.app
ALLOWED_HOSTS=TU-SERVICIO.run.app

# ── CLOUD SQL ───────────────────────────────────────────────────
DB_NAME=shieldgrid_db
DB_USER=shieldgrid_user
DB_PASSWORD=la-password-que-creaste-en-cloud-sql
CLOUD_SQL_CONNECTION_NAME=TU-PROYECTO:us-central1:shieldgrid-db

# ── CORS / CSRF ─────────────────────────────────────────────────
# Reemplaza con tu URL real de Firebase después del deploy del frontend
CORS_ALLOWED_ORIGINS=https://TU-APP.web.app
CSRF_TRUSTED_ORIGINS=https://TU-APP.web.app

# ── FRONTEND ────────────────────────────────────────────────────
FRONTEND_URL=https://TU-APP.web.app

# ── JWT ─────────────────────────────────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME_HOURS=8
JWT_REFRESH_TOKEN_LIFETIME_DAYS=1

# ── EMAIL (Mailtrap para staging, cambiar a Gmail en producción) ─
EMAIL_HOST=sandbox.smtp.mailtrap.io
EMAIL_HOST_USER=tu-usuario-mailtrap
EMAIL_HOST_PASSWORD=tu-password-mailtrap
EMAIL_PORT=2525
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
DEFAULT_FROM_EMAIL=Sistema GRC <noreply@grc.com>

# ── SUPABASE (para storage de evidencias) ───────────────────────
SUPABASE_URL=https://TU-PROYECTO.supabase.co
SUPABASE_KEY=tu-supabase-anon-key

# ── SUPERADMIN (solo para el primer deploy) ─────────────────────
SUPERADMIN_EMAIL=superadmin@sistema.com
SUPERADMIN_PASSWORD=cambia-esto-por-algo-seguro
SUPERADMIN_NOMBRE=Super Admin